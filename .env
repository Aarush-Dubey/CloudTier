APP_NAME=CloudTier

KAFKA_SERVER=kafka:29092
ACCESS_TOPIC=access_events
MIGRATION_TOPIC=migration_commands
DEAD_LETTER_TOPIC=dead_letter_events
CONSUMER_GROUP=cloudtier-consumers

MONGO_URI=mongodb://mongodb:27017/
DB_NAME=cloudtier

PRODUCER_DATASET_COUNT=1000
PRODUCER_SIM_SPEED_SEC=0.5
PRODUCER_CYCLE_DAYS=30

HOT_READ_THRESHOLD=100
COLD_READ_THRESHOLD=10
MAX_JOB_ATTEMPTS=3
RETRY_BACKOFF_SEC=3
METRICS_PORT=9100
